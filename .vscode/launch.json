{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run RiskManagement with Live Data",
      "runtimeExecutable": "cds",
      "killBehavior": "polite",
      "request": "launch",
      "args": [
        "watch",
        "--open"
      ],
      "console": "internalConsole",
      "internalConsoleOptions": "openOnSessionStart",
      "type": "pwa-node",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "PreLaunchTask for Run RiskManagement with Live Data",
      "envFile": "${workspaceFolder}/env/.env1",
      "env": {
        "run.config": "{\"handlerId\":\"lcap_run_config_handler_id\",\"runnableId\":\"{\\\"projectPath\\\":\\\"/home/user/projects/RiskManagement\\\",\\\"profileName\\\":\\\"\\\",\\\"odataServices\\\":[{\\\"id\\\":\\\"API_BUSINESS_PARTNER__1_\\\",\\\"liveData\\\":{\\\"type\\\":\\\"Destination\\\",\\\"destinationName\\\":\\\"apihub_sandbox\\\"}}]}\"}",
        "cds_requires_API_BUSINESS_PARTNER__1___credentials_destination": "apihub_sandbox",
        "runConfigurations": "{\"odataBinding\":{\"API_BUSINESS_PARTNER__1_\":{\"destination\":\"apihub_sandbox\",\"type\":\"Destination\",\"path\":\"\"}}}"
      }
    },
    {
      "name": "Run RiskManagement",
      "runtimeExecutable": "cds",
      "killBehavior": "polite",
      "request": "launch",
      "args": [
        "watch",
        "--open"
      ],
      "console": "internalConsole",
      "internalConsoleOptions": "openOnSessionStart",
      "type": "pwa-node",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "PreLaunchTask for Run RiskManagement",
      "envFile": "${workspaceFolder}/env/.env1",
      "env": {
        "run.config": "{\"handlerId\":\"lcap_run_config_handler_id\",\"runnableId\":\"{\\\"projectPath\\\":\\\"/home/user/projects/RiskManagement\\\",\\\"profileName\\\":\\\"\\\"}\"}"
      }
    }
  ]
}